(function(...)
    -- Reel A Brainrot - Fixed Version (vararg wrapper + dropdown recreate fix)
    -- by FayyScript (diperbaiki untuk executor seperti Delta/Synapse dll)

    local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Players = game:GetService("Players")
    local player = Players.LocalPlayer

    local RemoteHandler = ReplicatedStorage:WaitForChild("RemoteHandler", 10)

    local FishingEvent  = RemoteHandler and RemoteHandler:FindFirstChild("Fishing")
    local CollectEvent  = RemoteHandler and RemoteHandler:FindFirstChild("Collect")
    local SellEvent     = RemoteHandler and RemoteHandler:FindFirstChild("SellMultiple")
    local UpgradeEvent  = RemoteHandler and RemoteHandler:FindFirstChild("Upgrade")
    local PlotEvent     = RemoteHandler and RemoteHandler:FindFirstChild("Plot")
    local RodMutationEvent = RemoteHandler and RemoteHandler:FindFirstChild("RodMutation")
    local BuyPowerEvent = RemoteHandler and RemoteHandler:FindFirstChild("BuyPower")
    local MerchantBuyEvent = RemoteHandler and RemoteHandler:FindFirstChild("StPatricksMerchantBuy")
    local MerchantResetEvent = RemoteHandler and RemoteHandler:FindFirstChild("StPatricksMerchantResetStock")
    local MerchantSnapshotEvent = RemoteHandler and RemoteHandler:FindFirstChild("StPatricksMerchantSnapshot")

    print("FayyScript - Remote Status:")
    print("Fishing:", FishingEvent and "Found" or "Missing")
    print("Collect:", CollectEvent and "Found" or "Missing")
    print("SellMultiple:", SellEvent and "Found" or "Missing")
    print("Upgrade:", UpgradeEvent and "Found" or "Missing")
    print("Plot:", PlotEvent and "Found" or "Missing")
    print("RodMutation:", RodMutationEvent and "Found" or "Missing")
    print("BuyPower:", BuyPowerEvent and "Found" or "Missing")
    print("Merchant Buy:", MerchantBuyEvent and "Found" or "Missing")
    print("Merchant Reset:", MerchantResetEvent and "Found" or "Missing")
    print("Merchant Snapshot:", MerchantSnapshotEvent and "Found" or "Missing")

    -- Data Rod Mutation
    local RodMutations = {
        ["RodMutation1"] = { name = "Sparks", luck = 5, speed = 10, cost = 10000000, rebirths = 1 },
        ["RodMutation2"] = { name = "Ember", luck = 10, speed = 20, cost = 250000000, rebirths = 2 },
        ["RodMutation3"] = { name = "Frostbite", luck = 15, speed = 40, cost = 10000000000, rebirths = 3 },
        ["RodMutation4"] = { name = "Galactic", luck = 20, speed = 80, cost = 100000000000, rebirths = 4 },
        ["RodMutation5"] = { name = "Void", luck = 25, speed = 100, cost = 5000000000000, rebirths = 5 },
        ["RodMutation6"] = { name = "Glitch", luck = 30, speed = 120, cost = 500000000000000, rebirths = 8 },
        ["RodMutation7"] = { name = "Admin", luck = 35, speed = 150, cost = 5000000000000000, rebirths = 10 }
    }

    local function GetMerchantSnapshot()
        if not MerchantSnapshotEvent then return nil end
        local success, result = pcall(function()
            return MerchantSnapshotEvent:InvokeServer()
        end)
        if success and result then
            if type(result) == "table" then
                if #result > 0 and type(result[1]) == "table" then return result[1] end
                return result
            end
        end
        return nil
    end

    local function RefreshMerchantStock()
        if not MerchantResetEvent then return false, "Reset event not found" end
        local success = pcall(function()
            MerchantResetEvent:InvokeServer()
        end)
        return success, success and "Stock reset successful" or "Failed to reset stock"
    end

    local function GetMerchantItemsFromSnapshot()
        local snapshot = GetMerchantSnapshot()
        if not snapshot then return {} end
        local items = {}
        if snapshot.offers and type(snapshot.offers) == "table" then
            for _, offer in ipairs(snapshot.offers) do
                if offer.stock and offer.stock > 0 then
                    local itemName = offer.displayName or offer.id
                    if offer.kind == "Brainrot" and offer.displayName then
                        itemName = offer.displayName
                    end
                    items[offer.id] = {
                        name = itemName,
                        desc = offer.kind == "Brainrot" and string.format("Level %d Brainrot - $%s/s", offer.level or 1, tostring(offer.mps or 0)) or "",
                        price = offer.cost or 0,
                        stock = offer.stock,
                        maxStock = offer.maxStock or offer.stock,
                        oneTime = offer.oneTime or false,
                        kind = offer.kind or "Unknown",
                        level = offer.level,
                        mps = offer.mps,
                        rarity = offer.rarity
                    }
                end
            end
        end
        return items
    end

    local MerchantItems = {}

    local function GetAvailableItemsList()
        local items = {}
        for itemId, itemData in pairs(MerchantItems) do
            if itemData.stock > 0 then
                local displayName = string.format("%s - $%s [Stock: %d/%d]", 
                    itemData.name, 
                    tostring(itemData.price),
                    itemData.stock,
                    itemData.maxStock)
                table.insert(items, {
                    id = itemId,
                    display = displayName,
                    data = itemData
                })
            end
        end
        table.sort(items, function(a, b) return a.data.name < b.data.name end)
        return items
    end

    local function RefreshItemList()
        local newItems = GetMerchantItemsFromSnapshot()
        if next(newItems) then MerchantItems = newItems end
        return GetAvailableItemsList()
    end

    local ItemList = RefreshItemList()

    local Settings = {
        AutoFish = false,
        AutoBuyItems = false,
        AutoResetStock = false,
        ResetStockDelay = 300,
        BuyDelay = 5,
        PowerType = "power10",
        RodMutationType = "RodMutation1",
        SelectedItem = nil,
        SelectedItemDisplay = nil,
        SellRarities = {
            Common = false, Uncommon = false, Rare = false, Epic = false,
            Legendary = false, Godly = false, Mythic = false, Secret = false, Divine = false
        }
    }

    local function safeFire(event, ...)
        if event and typeof(event) == "Instance" then
            pcall(function() event:FireServer(...) end)
        end
    end

    local function safeInvoke(event, ...)
        if event and typeof(event) == "Instance" then
            local s, r = pcall(function() return event:InvokeServer(...) end)
            return s, r
        end
        return false, nil
    end

    local function InstantFish() safeFire(FishingEvent, "Caught", 2) end

    local function CollectAllPlots()
        if not CollectEvent then return end
        for i = 1, 30 do
            safeFire(CollectEvent, "Plot" .. i)
            task.wait(0.08 + math.random() * 0.04)
        end
    end

    local function SellSelected() safeFire(SellEvent, Settings.SellRarities) end

    local function UpgradePower() safeFire(UpgradeEvent, Settings.PowerType) end

    local function BuyPower()
        if BuyPowerEvent then
            safeFire(BuyPowerEvent, "Buy", Settings.PowerType)
        else
            safeFire(UpgradeEvent, Settings.PowerType)
        end
    end

    local function UpgradeBase() safeFire(UpgradeEvent, "BaseLevel") end

    local function EquipBestBrainrot()
        safeFire(PlotEvent, "EquipBest", "Plot1", "Brainrot")
        task.wait(0.1)
        safeFire(PlotEvent, "EquipBest", "1", "Brainrot")
    end

    local function BuyRodMutation() safeFire(RodMutationEvent, "Buy", Settings.RodMutationType) end

    local function BuyMerchantItem(itemId)
        if not MerchantBuyEvent then return false end
        local success = safeInvoke(MerchantBuyEvent, itemId)
        if success then
            if MerchantItems[itemId] then
                MerchantItems[itemId].stock = math.max(0, MerchantItems[itemId].stock - 1)
            end
            return true
        end
        return false
    end

    -- Auto loops
    task.spawn(function()
        while true do
            if Settings.AutoFish then InstantFish() end
            task.wait(1.5 + math.random(-3, 4) / 10)
        end
    end)

    task.spawn(function()
        while true do
            if Settings.AutoBuyItems and Settings.SelectedItem then
                local stock = MerchantItems[Settings.SelectedItem] and MerchantItems[Settings.SelectedItem].stock or 0
                if stock > 0 then
                    local success = BuyMerchantItem(Settings.SelectedItem)
                    if success then
                        task.spawn(function()
                            task.wait(0.4)
                            UpdateItemDropdown()
                        end)
                    end
                end
                task.wait(Settings.BuyDelay)
            end
            task.wait(1)
        end
    end)

    task.spawn(function()
        while true do
            if Settings.AutoResetStock and MerchantResetEvent then
                local success = RefreshMerchantStock()
                if success then
                    task.spawn(function()
                        task.wait(0.6)
                        UpdateItemDropdown()
                    end)
                end
                task.wait(Settings.ResetStockDelay)
            end
            task.wait(1)
        end
    end)

    -- UI
    local Window = WindUI:CreateWindow({
        Title = "Reel Brainrot",
        Icon = "fish",
        Author = "by FayyScript",
        Folder = "FayyScript",
        Size = UDim2.fromOffset(580, 420),
        Transparent = true,
        Theme = "Dark",
        SideBarWidth = 180,
        HasOutline = true,
    })

    local MainTab = Window:Tab({ Title = "Main", Icon = "fish" })
    MainTab:Section({ Title = "⚡ Fishing" })
    MainTab:Toggle({ Title = "Auto Instant Fish", Value = false, Callback = function(v) Settings.AutoFish = v end })
    MainTab:Button({ Title = "🎣 Fish Now", Callback = InstantFish })

    MainTab:Section({ Title = "💰 Collect Money" })
    MainTab:Button({ Title = "Collect All Plots", Callback = CollectAllPlots })

    MainTab:Section({ Title = "⚔️ Equipment" })
    MainTab:Button({ Title = "Equip Best Brainrot", Callback = EquipBestBrainrot })

    -- Sell Tab (singkat)
    local SellTab = Window:Tab({ Title = "Sell Custom", Icon = "banknote" })
    SellTab:Section({ Title = "🎯 Select Rarities" })
    local rarityOrder = {"Common","Uncommon","Rare","Epic","Legendary","Godly","Mythic","Secret","Divine"}
    for _, r in ipairs(rarityOrder) do
        SellTab:Toggle({ Title = "Sell "..r, Value = Settings.SellRarities[r], Callback = function(v) Settings.SellRarities[r] = v end })
    end
    SellTab:Button({ Title = "Sell Selected", Callback = SellSelected })

    -- Shop Tab (singkat)
    local ShopTab = Window:Tab({ Title = "Shop", Icon = "shopping-cart" })
    ShopTab:Section({ Title = "Power Upgrades" })
    ShopTab:Dropdown({ Title = "Select Power", Values = {"power1","power5","power10"}, Value = "power10", Callback = function(v) Settings.PowerType = v end })
    ShopTab:Button({ Title = "Buy Power", Callback = BuyPower })
    ShopTab:Button({ Title = "Upgrade Base", Callback = UpgradeBase })

    ShopTab:Section({ Title = "Rod Mutations" })
    local mutOpts = {}
    for _, d in pairs(RodMutations) do table.insert(mutOpts, d.name) end
    ShopTab:Dropdown({ Title = "Select Mutation", Values = mutOpts, Value = mutOpts[1], Callback = function(opt)
        for id, d in pairs(RodMutations) do if d.name == opt then Settings.RodMutationType = id break end end
    end })
    ShopTab:Button({ Title = "Buy Rod Mutation", Callback = BuyRodMutation })

    -- Merchant Tab (bagian paling penting - dropdown di-recreate)
    local MerchantTab = Window:Tab({ Title = "St. Patrick", Icon = "gift" })
    local itemDropdown = nil

    local function DestroyItemDropdown()
        if itemDropdown and itemDropdown.Destroy then
            pcall(function() itemDropdown:Destroy() end)
            itemDropdown = nil
        end
    end

    function UpdateItemDropdown()
        ItemList = RefreshItemList()
        local displays = {}
        for _, item in ipairs(ItemList) do table.insert(displays, item.display) end

        DestroyItemDropdown()

        if #ItemList > 0 then
            itemDropdown = MerchantTab:Dropdown({
                Title = "Select Item",
                Desc = "Pilih item untuk dibeli",
                Values = displays,
                Value = displays[1],
                Callback = function(selected)
                    for _, item in ipairs(ItemList) do
                        if item.display == selected then
                            Settings.SelectedItem = item.id
                            Settings.SelectedItemDisplay = item.display
                            break
                        end
                    end
                end
            })
            if #ItemList > 0 then
                Settings.SelectedItem = ItemList[1].id
                Settings.SelectedItemDisplay = ItemList[1].display
            end
        else
            MerchantTab:Paragraph({
                Title = "Tidak Ada Item",
                Desc = "Stok kosong. Coba Refresh atau Reset Stock."
            })
        end
    end

    MerchantTab:Section({ Title = "Buy Controls" })
    MerchantTab:Button({
        Title = "Buy Selected Item",
        Callback = function()
            if not Settings.SelectedItem then return end
            local success = BuyMerchantItem(Settings.SelectedItem)
            if success then
                task.spawn(function()
                    task.wait(0.4)
                    UpdateItemDropdown()
                end)
            end
        end
    })

    MerchantTab:Button({ Title = "🔄 Refresh Stock", Callback = UpdateItemDropdown })
    MerchantTab:Button({
        Title = "Reset Stock Now",
        Callback = function()
            RefreshMerchantStock()
            task.wait(0.6)
            UpdateItemDropdown()
        end
    })

    MerchantTab:Section({ Title = "Available Items" })
    UpdateItemDropdown()  -- initial load

    MerchantTab:Section({ Title = "Auto Settings" })
    MerchantTab:Toggle({ Title = "Auto Buy", Callback = function(v) Settings.AutoBuyItems = v end })
    MerchantTab:Toggle({ Title = "Auto Reset Stock", Callback = function(v) Settings.AutoResetStock = v end })
    MerchantTab:Slider({ Title = "Buy Delay (s)", Min = 1, Max = 30, Default = 5, Callback = function(v) Settings.BuyDelay = v end })
    MerchantTab:Slider({ Title = "Reset Delay (s)", Min = 60, Max = 3600, Default = 300, Callback = function(v) Settings.ResetStockDelay = v end })

    print("Reel Brainrot - Fixed & Loaded!")
end)(...)
